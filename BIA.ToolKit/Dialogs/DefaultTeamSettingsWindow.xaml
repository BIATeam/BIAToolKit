<UserControl x:Class="BIA.ToolKit.Dialogs.DefaultTeamSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BIA.ToolKit.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        MinWidth="400" MaxWidth="400"
        d:DataContext="{d:DesignInstance Type=vm:DefaultTeamSettingsViewModel, IsDesignTimeCreatable=False}">
    <UserControl.Resources>
        <Thickness x:Key="FormFieldMargin">0,0,0,8</Thickness>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Default Team Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBox Margin="{StaticResource FormFieldMargin}"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     materialDesign:HintAssist.Hint="Team Name (Singular)"
                     Text="{Binding DefaultTeamName, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap"/>
            <TextBox Margin="{StaticResource FormFieldMargin}"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     materialDesign:HintAssist.Hint="Team Name (Plural)"
                     Text="{Binding DefaultTeamNamePlural, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap"/>
            <TextBox Margin="{StaticResource FormFieldMargin}"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     materialDesign:HintAssist.Hint="Domain Name"
                     Text="{Binding DefaultTeamDomainName, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Margin="0,16,0,0" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="5" Style="{StaticResource MaterialDesignFlatButton}"
                    IsEnabled="{Binding IsValid}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="True">OK</Button>
            <Button Margin="5" Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="False">CANCEL</Button>
        </StackPanel>
    </Grid>
</UserControl>
