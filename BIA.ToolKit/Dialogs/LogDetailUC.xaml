<UserControl x:Class="BIA.ToolKit.Dialogs.LogDetailUC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        MinWidth="600" MaxWidth="1000" MaxHeight="700"
        DataContext="{Binding Source={StaticResource Locator}, Path=LogDetailViewModel}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Log Detail" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

        <RichTextBox Grid.Row="1" Name="OutputDetailRichTextBox"
                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     BorderThickness="0" Padding="5"
                     Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     MaxHeight="500">
            <RichTextBox.Document>
                <FlowDocument PagePadding="0"/>
            </RichTextBox.Document>
        </RichTextBox>

        <StackPanel Grid.Row="2" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="5" Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding CopyToClipboardCommand}">COPY TO CLIPBOARD</Button>
            <Button Margin="5" Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="True">CLOSE</Button>
        </StackPanel>
    </Grid>
</UserControl>
