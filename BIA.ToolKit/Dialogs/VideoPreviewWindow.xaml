<Window x:Class="BIA.ToolKit.Dialogs.VideoPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#CC000000"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="Feature demo">
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="OnCloseExecuted"/>
    </Window.CommandBindings>

    <!-- Clicking the dark backdrop closes the modal (fires only if hit-test stays on this Grid). -->
    <Grid MouseLeftButtonDown="OnBackdropClick">
        <Border Background="Black"
                CornerRadius="8"
                Margin="32"
                BorderBrush="#444"
                BorderThickness="1"
                ClipToBounds="True"
                MouseLeftButtonDown="OnContentClick">
            <Grid>
                <MediaElement x:Name="PreviewMedia"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              IsMuted="True"
                              Stretch="Uniform"
                              ScrubbingEnabled="True"
                              MediaOpened="Media_OnOpened"
                              MediaEnded="Media_OnEnded"/>

                <!-- LIVE DEMO badge -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16"
                        Padding="6,3" CornerRadius="3" Background="#CC000000">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#E53935" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="LIVE DEMO" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Close button -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                        Width="36" Height="36" Padding="0"
                        Background="#80000000" BorderThickness="0"
                        Foreground="White"
                        Command="ApplicationCommands.Close"
                        ToolTip="Close (Esc)">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
