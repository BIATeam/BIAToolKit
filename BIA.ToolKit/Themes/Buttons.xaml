<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        Shared action button styles. Foreground uses MDIX's on-color brushes
        (MaterialDesign.Brush.Primary.Foreground / .Secondary.Foreground) which
        MDIX recomputes when PaletteHelper.SetPrimaryColor/SetSecondaryColor runs,
        so contrast is maintained across theme switches without hardcoding White.
    -->

    <!-- Primary CTA: main action per screen. Primary-colored background. -->
    <Style x:Key="Button.PrimaryAction" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
    </Style>

    <!-- Secondary CTA: used by all current CTAs (Create, Generate x3, Migrate, Regenerate).
         Replaces the hardcoded Foreground="White" that produced ~1.2:1 contrast on the Lime dark theme. -->
    <Style x:Key="Button.SecondaryAction" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignRaisedSecondaryButton}">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"/>
    </Style>

    <!-- Ghost: flat button for tertiary actions. -->
    <Style x:Key="Button.Ghost" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
    </Style>

    <!-- Warning: DEV-mode exit, destructive confirms. Black on #FF9800 = ratio ~10:1 (AAA). -->
    <Style x:Key="Button.Warning" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="#FF9800"/>
        <Setter Property="BorderBrush" Value="#FF9800"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>

    <!-- Compact icon button: small toolbar edit/refresh icons. -->
    <Style x:Key="Button.IconCompact" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignIconButton}">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
    </Style>
</ResourceDictionary>
