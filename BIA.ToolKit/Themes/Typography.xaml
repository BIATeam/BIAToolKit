<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Centralized text styles with WCAG AA-safe opacities.
        Foreground is pinned to MaterialDesign.Brush.Foreground so color tracks
        the active theme. Opacity values stay above the 4.5:1 ratio on the theme background.

        - Text.Body     : opacity 1.0  -> AAA at any size
        - Text.Heading  : opacity 1.0  -> AAA, SemiBold, 18pt
        - Text.Caption  : opacity 0.87 -> AA at any size (default for secondary text)
        - Text.Subtle   : opacity 0.70 -> AA for LARGE text only (>= 14pt). Do NOT use < 14pt.
    -->

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="Text.Heading" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Text.Caption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
        <Setter Property="Opacity" Value="0.87"/>
    </Style>

    <Style x:Key="Text.Subtle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
        <Setter Property="Opacity" Value="0.70"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
</ResourceDictionary>
