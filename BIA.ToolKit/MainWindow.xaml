<Window x:Class="BIA.ToolKit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:vm="clr-namespace:BIA.ToolKit.ViewModels"
        xmlns:uc="clr-namespace:BIA.ToolKit.UserControls" d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStyle="None"
        Title="BIA Toolkit" Height="820" Width="1300" Icon="/Images/Tools.ico" WindowStartupLocation="CenterScreen" MinHeight="800" MinWidth="1300"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.25*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0" Height="36" Background="{DynamicResource MaterialDesign.Brush.AppBar.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <!-- App icon + title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0">
                <Image Source="/Images/Tools.ico" Width="18" Height="18" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Center"/>
                <TextBlock Text="BIA Toolkit" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            </StackPanel>

            <!-- Version + update controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True" Margin="0,0,8,0">
                <Button Height="18" Padding="0" x:Name="UpdateButton" VerticalAlignment="Center"
                        ToolTip="New version available !" Background="Transparent" Foreground="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisConverter}}"
                        Command="{Binding PromptAndDownloadUpdateCommand}">
                    <Image Source="/Images/update.png" />
                </Button>
                <TextBlock Text="{Binding ApplicationVersion}" VerticalAlignment="Center" FontSize="11"
                           d:Text="V0.0.0.0" Margin="4,0"/>
                <Button Height="16" Width="16" x:Name="CheckUpdateButton" VerticalAlignment="Center"
                        ToolTip="Check for update" Padding="0" Margin="2,0"
                        Command="{Binding CheckForUpdateCommand}" IsEnabled="{Binding IsCheckUpdateEnabled}"
                        Style="{StaticResource MaterialDesignFlatButton}">
                    <Image Source="/Images/rafraichir-32.png" Cursor="Hand" RenderOptions.BitmapScalingMode="Fant" />
                </Button>
                <CheckBox Name="AutoUpdateCheckbox" IsChecked="{Binding Settings_AutoUpdate}"
                          VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock Text="Auto update" VerticalAlignment="Center" FontSize="10" Margin="2,0,0,0"/>
            </StackPanel>

            <!-- Theme toggle -->
            <Button Grid.Column="3" x:Name="ThemeButton"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="ThemeToggleClick"
                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                    Width="40" Height="36"
                    materialDesign:RippleAssist.IsDisabled="True"
                    ToolTip="Basculer thème Sombre/Clair">
                <materialDesign:PackIcon x:Name="ThemeIcon" Kind="WeatherNight" Width="18" Height="18"/>
            </Button>

            <!-- Window buttons -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton" Click="MinimizeClick" Width="46" Height="36"
                        Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                        materialDesign:RippleAssist.IsDisabled="True">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                </Button>
                <Button x:Name="MaximizeButton" Click="MaximizeClick" Width="46" Height="36"
                        Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                        materialDesign:RippleAssist.IsDisabled="True">
                    <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16" x:Name="MaximizeIcon"/>
                </Button>
                <Button x:Name="CloseButton" Click="CloseClick" Width="46" Height="36"
                        Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                        materialDesign:RippleAssist.IsDisabled="True">
                    <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="0.02*"/>
            </Grid.RowDefinitions>
            <Grid Background="{DynamicResource MaterialDesign.Brush.Background}" Opacity="0.2"/>
            <TabControl Grid.Row="0" Name="MainTab">
                <TabItem Header="CONFIGURATION">
                    <Grid Background="{DynamicResource MaterialDesign.Brush.Background}" x:Name="TabConfig">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Image gif:ImageBehavior.AnimatedSource="Images/LogoBIA.png" Grid.RowSpan="2" Opacity="0.6"/>

                            <Grid Grid.Row="0" Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5">
                                    <Button x:Name="ImportConfigButton" Height="35" Command="{Binding ImportConfigCommand}" Margin="0,0,5,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Import" Height="25" Width="25"/>
                                            <TextBlock Text="Import Configuration" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="ExportConfigButton" Height="35" Style="{StaticResource MaterialDesignPaperButton}" Command="{Binding ExportConfigCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Export Configuration" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <materialDesign:PackIcon Kind="Export" Height="25" Width="25"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Grid Grid.Column="1">
                                    <Button Margin="0,5" Style="{StaticResource MaterialDesignPaperButton}" Content="Toolkit Repository Settings" Width="auto" HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding OpenToolkitRepositorySettingsCommand}"/>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="1" Margin="30,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="0.05*"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.RowSpan="2" Background="{DynamicResource MaterialDesign.Brush.Background}" Opacity="0.4"/>
                                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,5">
                                        <Label Grid.Row="0" Margin="0,2,0,0" Content="TEMPLATES REPOSITORIES" FontWeight="Bold" FontSize="25"/>
                                        <Button Padding="5,0" Margin="10,0,0,0"  Command="{Binding AddTemplateRepositoryCommand}" ToolTip="Add Template Repository">
                                            <materialDesign:PackIcon Kind="Add" Height="25" Width="25"/>
                                        </Button>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible" Margin="10,0,0,0">
                                        <ItemsControl ItemsSource="{Binding TemplateRepositories}" VerticalAlignment="Top">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:RepositoryViewModel}">
                                                    <uc:RepositoryResumeUC Margin="0,0,0,10" DataContext="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>


                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.RowSpan="2" Background="{DynamicResource MaterialDesign.Brush.Background}" Opacity="0.4"/>
                                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,5">
                                        <ToggleButton Margin="0,0,10,0" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding Settings_UseCompanyFiles}" ToolTip="Use Company Files"/>
                                        <Label Grid.Row="0" Margin="0,2,0,0" Content="COMPANY FILES REPOSITORIES" FontWeight="Bold" FontSize="25" IsEnabled="{Binding Settings_UseCompanyFiles}"/>
                                        <Button Padding="5,0" Margin="10,0,0,0" Command="{Binding AddCompanyFilesRepositoryCommand}" ToolTip="Add Company Files Repository" IsEnabled="{Binding Settings_UseCompanyFiles}">
                                            <materialDesign:PackIcon Kind="Add" Height="25" Width="25"/>
                                        </Button>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible" Margin="10,0,0,0" IsEnabled="{Binding Settings_UseCompanyFiles}">
                                        <ItemsControl ItemsSource="{Binding CompanyFilesRepositories}" VerticalAlignment="Top">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:RepositoryViewModel}">
                                                    <uc:RepositoryResumeUC Margin="0,0,0,10" DataContext="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="CREATION" Selector.Selected="OnTabSelected">
                    <Grid x:Name="TabCreate">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.5*"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.Background>
                            <ImageBrush Opacity="0.7" ImageSource="/Images/bg-default.jpg"/>
                        </Grid.Background>

                        <Grid Grid.Row="0" Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Projects Parent Path" Text="{Binding Settings_RootProjectsPath}" TextWrapping="Wrap"/>
                                <Button Grid.Column="1" Margin="5" Content="..." Command="{Binding BrowseCreateRootFolderCommand}"/>
                            </Grid>
                            <Grid Grid.Column="1" Margin="10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Company Name" Text="{Binding Settings_CreateCompanyName}" TextWrapping="Wrap"/>
                                <TextBox Margin="0,10" Grid.Row="1" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Project Name" Text="{Binding CreateProjectName, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" x:Name="CreateProjectName" IsEnabled="True"/>
                            </Grid>
                            <Button Grid.Column="2" Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Height="50" Width="150" Content="Create" HorizontalAlignment="Right" Command="{Binding CreateProjectCommand}" VerticalAlignment="Top"/>
                        </Grid>

                        <uc:VersionAndOptionUserControl Grid.Row="1" VerticalAlignment="Bottom" x:Name="CreateVersionAndOption" Margin="10" Height="auto"/>
                    </Grid>
                </TabItem>
                <TabItem Header="MIGRATION" Selector.Selected="OnTabSelected">
                    <Grid>
                        <Grid.Background>
                            <ImageBrush Opacity="0.3" ImageSource="/Images/workOnComputer2.jpg" Stretch="UniformToFill"/>
                        </Grid.Background>
                        <uc:ModifyProjectUC x:Name="ModifyProject"/>
                    </Grid>
                </TabItem>
                <TabItem Header="GENERATION" Selector.Selected="OnTabSelected">
                    <Grid>
                        <Grid.Background>
                            <ImageBrush Opacity="0.3" ImageSource="/Images/workOnComputer2.jpg" Stretch="UniformToFill"/>
                        </Grid.Background>
                        <uc:GenerateUC x:Name="GenerateProject"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Grid Grid.Row="2" Margin="10,0,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- OUTPUT header with action buttons -->
            <Grid Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" FontWeight="Bold" Content="OUTPUT" Padding="10,4"
                       FontSize="11" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Opacity="0.6"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button x:Name="StopButton" Command="{Binding StopActionCommand}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="4" Width="28" Height="28" Margin="0,0,2,0"
                            ToolTip="Stop current action">
                        <materialDesign:PackIcon Kind="Stop" Width="16" Height="16" Foreground="IndianRed"/>
                    </Button>
                    <Button Command="{Binding ClearConsoleCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="4" Width="28" Height="28" Margin="0,0,2,0"
                            ToolTip="Clear console">
                        <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding CopyConsoleToClipboardCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="4" Width="28" Height="28"
                            ToolTip="Copy to clipboard">
                        <materialDesign:PackIcon Kind="ContentCopy" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Console output -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Name="OutputTextViewer">
                <TextBlock Name="OutputText" TextWrapping="Wrap" LineHeight="10" Padding="5"
                           Background="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="Waiter" Grid.Row="1" Grid.RowSpan="2" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}" d:Visibility="Hidden">
            <Grid Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Card.Background}" Opacity="0.8" />
            <Image gif:ImageBehavior.AnimatedSource="Images\spinner_light.gif" Height="200"/>
        </Grid>

    </Grid>
</Window>
