<Window x:Class="BIA.ToolKit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:vm="clr-namespace:BIA.ToolKit.ViewModels"
        xmlns:uc="clr-namespace:BIA.ToolKit.UserControls"
        xmlns:inf="clr-namespace:BIA.ToolKit.Infrastructure"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStyle="None"
        Title="BIA Toolkit" Height="820" Width="1300" Icon="/Images/Tools.ico" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding StopActionCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <inf:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <inf:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
        <inf:EnumToVisibilityMultiConverter x:Key="EnumToVisibilityMultiConverter"/>
        <inf:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter"/>
        <inf:WidthToVisibilityConverter x:Key="WidthToVisibilityConverter"/>

        <!-- Navigation Rail Item Style -->
        <Style x:Key="NavRailItem" TargetType="RadioButton">
            <Setter Property="GroupName" Value="MainNav"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="Transparent" Height="64" Width="72">
                            <Grid>
                                <Border x:Name="Overlay" Background="{DynamicResource MaterialDesign.Brush.Foreground}"
                                        Opacity="0" IsHitTestVisible="False"/>
                                <Border x:Name="Indicator" Width="3" HorizontalAlignment="Left"
                                        Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                        CornerRadius="0,2,2,0" Visibility="Collapsed"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.08"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.04"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <materialDesign:DialogHost x:Name="RootDialogHost" Identifier="RootDialog"
                               DialogTheme="Inherit"
                               CloseOnClickAway="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="{Binding IsOutputMaximized, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=TrueZero}"/>
            <RowDefinition Height="{Binding IsOutputMaximized, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=TrueStar}"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0" Height="36" Background="{DynamicResource MaterialDesign.Brush.AppBar.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <!-- App icon + title + version (grouped as "app identity") -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Logo: 7 successive clicks (<2s between clicks) toggle DEV mode ON. -->
                <Border x:Name="LogoHitArea" Cursor="Hand" Background="Transparent"
                        MouseLeftButtonDown="LogoClick"
                        ToolTip="BIA Toolkit">
                    <Image Source="/Images/Tools.ico" Width="18" Height="18"
                           RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="BIA Toolkit" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                <Button Height="18" Padding="0" x:Name="UpdateButton" VerticalAlignment="Center" Margin="8,0,0,0"
                        ToolTip="New version available !" Background="Transparent" Foreground="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisConverter}}"
                        Command="{Binding PromptAndDownloadUpdateCommand}">
                    <Image Source="/Images/update.png" />
                </Button>
                <TextBlock Text="{Binding ApplicationVersion}" VerticalAlignment="Center" FontSize="11"
                           d:Text="V0.0.0.0" Margin="8,0,0,0" Opacity="0.6"/>

                <!-- Exit DEV button: visible only when developer mode is ON.
                     Warning-orange styling so it's impossible to forget you're in DEV. -->
                <Button x:Name="ExitDevButton" Click="ExitDevClick"
                        Visibility="{Binding AppSession.IsDeveloperMode, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"
                        Margin="10,0,0,0" VerticalAlignment="Center"
                        Height="22" Padding="8,0" MinWidth="0"
                        Background="#FF9800" BorderBrush="#FF9800" Foreground="White"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:RippleAssist.IsDisabled="True"
                        ToolTip="DEV mode is ON — click to exit">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BugOutline" Width="13" Height="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Exit DEV" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Live window diagnostics (DEV mode only): window size, state,
                     current monitor work area, and DPI scale. Helps debug the
                     "maximized window overshoots screen" class of bugs. -->
                <TextBlock x:Name="DevDiagnosticsText"
                           Visibility="{Binding AppSession.IsDeveloperMode, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"
                           Margin="10,0,0,0" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="10" Foreground="#FF9800" Opacity="0.85"
                           ToolTip="Window size · state · monitor work area · DPI scale"/>
            </StackPanel>

            <!-- Update actions (shrinks first; right-aligned so the buttons stay visible) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True" Margin="0,0,8,0">
                <Button Height="16" Width="16" x:Name="CheckUpdateButton" VerticalAlignment="Center"
                        ToolTip="Check for update" Padding="0" Margin="2,0"
                        Command="{Binding CheckForUpdateCommand}" IsEnabled="{Binding IsCheckUpdateEnabled}"
                        Style="{StaticResource MaterialDesignFlatButton}">
                    <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" Cursor="Hand"
                                          Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                </Button>
                <CheckBox Name="AutoUpdateCheckbox" IsChecked="{Binding Settings_AutoUpdate}"
                          VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock Text="Auto update" VerticalAlignment="Center" FontSize="10" Margin="2,0,0,0"/>
            </StackPanel>

            <!-- Theme toggle -->
            <Button Grid.Column="2" x:Name="ThemeButton"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="ThemeToggleClick"
                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                    Width="40" Height="36"
                    materialDesign:RippleAssist.IsDisabled="True"
                    ToolTip="Basculer thème Sombre/Clair">
                <materialDesign:PackIcon x:Name="ThemeIcon" Kind="WeatherNight" Width="18" Height="18"/>
            </Button>

            <!-- Window buttons -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton" Click="MinimizeClick" Width="46" Height="36"
                        Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                        materialDesign:RippleAssist.IsDisabled="True">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                </Button>
                <Button x:Name="MaximizeButton" Click="MaximizeClick" Width="46" Height="36"
                        Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                        materialDesign:RippleAssist.IsDisabled="True">
                    <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16" x:Name="MaximizeIcon"/>
                </Button>
                <Button x:Name="CloseButton" Click="CloseClick" Width="46" Height="36"
                        Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                        materialDesign:RippleAssist.IsDisabled="True">
                    <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: Navigation Rail + Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Rail -->
            <Border Grid.Column="0" Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <DockPanel>
                    <!-- Configuration at bottom, separated visually -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                        <Separator Margin="12,4"/>
                        <RadioButton x:Name="NavConfig" Style="{StaticResource NavRailItem}"
                                     IsChecked="{Binding SelectedPage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Configuration}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Cog" Width="24" Height="24" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                                <TextBlock Text="Config" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Main workflow sections -->
                    <StackPanel Margin="0,8,0,0">
                        <RadioButton x:Name="NavCreation" Style="{StaticResource NavRailItem}"
                                     IsChecked="{Binding SelectedPage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Creation}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FolderPlus" Width="24" Height="24" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                                <TextBlock Text="Création" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavMigration" Style="{StaticResource NavRailItem}"
                                     IsChecked="{Binding SelectedPage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Migration}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Sync" Width="24" Height="24" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                                <TextBlock Text="Migration" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavGeneration" Style="{StaticResource NavRailItem}"
                                     IsChecked="{Binding SelectedPage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Generation}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Flash" Width="24" Height="24" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                                <TextBlock Text="Génération" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Area (wrapped in ScrollViewer so that, when the window is narrower than the
                 comfortable layout width, horizontal scrolling kicks in instead of clipping the UI) -->
            <ScrollViewer Grid.Column="1" x:Name="ContentScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
            <Grid MinWidth="900"
                  Width="{Binding ViewportWidth, ElementName=ContentScroll}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Shared Project Selector (visible for Migration/Generation only) -->
                <uc:ProjectSelectorUC x:Name="SharedProjectSelector" Grid.Row="0" Margin="10"
                                      Visibility="{Binding DataContext.SelectedPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVisibilityMultiConverter}, ConverterParameter='Migration,Generation', FallbackValue=Collapsed}"/>

                <!-- Page content (stacked, visibility-switched) -->
                <Grid Grid.Row="2">

                    <!--#region Configuration Page -->
                    <Grid x:Name="PageConfig" Visibility="{Binding SelectedPage, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Configuration, FallbackValue=Collapsed}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Image gif:ImageBehavior.AnimatedSource="Images/LogoBIA.png" Grid.RowSpan="2" Opacity="0.6"/>

                            <Grid Grid.Row="0" Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5">
                                    <Button x:Name="ImportConfigButton" Height="35" Margin="0,0,5,0" Command="{Binding ImportConfigCommand}"
                                            ToolTip="Import Configuration">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Import" Height="25" Width="25"/>
                                            <TextBlock Text="Import Configuration" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="ExportConfigButton" Height="35" Style="{StaticResource MaterialDesignPaperButton}" Command="{Binding ExportConfigCommand}"
                                            ToolTip="Export Configuration">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Export Configuration" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <materialDesign:PackIcon Kind="Export" Height="25" Width="25"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Button Grid.Column="2" Height="35" Margin="10,5,0,5" VerticalAlignment="Top"
                                        Style="{StaticResource MaterialDesignPaperButton}"
                                        Command="{Binding OpenToolkitRepositorySettingsCommand}"
                                        ToolTip="Toolkit Repository Settings">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CogOutline" Height="20" Width="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="Toolkit Repository Settings" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1" Margin="30,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="0.05*"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.RowSpan="2" Background="{DynamicResource MaterialDesign.Brush.Background}" Opacity="0.4"/>
                                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,5">
                                        <Label Grid.Row="0" Margin="0,2,0,0" Content="TEMPLATES REPOSITORIES" FontWeight="Bold" FontSize="25"/>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Margin="10,0,0,0" Command="{Binding AddTemplateRepositoryCommand}" ToolTip="Add Template Repository"
                                                Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                            <materialDesign:PackIcon Kind="PlusCircle" Height="28" Width="28"/>
                                        </Button>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible" Margin="10,0,0,0">
                                        <ItemsControl ItemsSource="{Binding TemplateRepositories}" VerticalAlignment="Top">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:RepositoryViewModel}">
                                                    <uc:RepositoryResumeUC Margin="0,0,0,10" DataContext="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>

                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.RowSpan="2" Background="{DynamicResource MaterialDesign.Brush.Background}" Opacity="0.4"/>
                                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,5">
                                        <ToggleButton Margin="0,0,10,0" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding Settings_UseCompanyFiles}" ToolTip="Use Company Files"/>
                                        <Label Grid.Row="0" Margin="0,2,0,0" Content="COMPANY FILES REPOSITORIES" FontWeight="Bold" FontSize="25" IsEnabled="{Binding Settings_UseCompanyFiles}"/>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Margin="10,0,0,0" Command="{Binding AddCompanyFilesRepositoryCommand}" ToolTip="Add Company Files Repository" IsEnabled="{Binding Settings_UseCompanyFiles}"
                                                Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                            <materialDesign:PackIcon Kind="PlusCircle" Height="28" Width="28"/>
                                        </Button>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible" Margin="10,0,0,0" IsEnabled="{Binding Settings_UseCompanyFiles}">
                                        <ItemsControl ItemsSource="{Binding CompanyFilesRepositories}" VerticalAlignment="Top">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:RepositoryViewModel}">
                                                    <uc:RepositoryResumeUC Margin="0,0,0,10" DataContext="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                    <!--#endregion-->

                    <!--#region Creation Page -->
                    <Grid x:Name="PageCreate" Visibility="{Binding SelectedPage, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Creation, FallbackValue=Collapsed}">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Project configuration (single row: Path | Company | Project) -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" VerticalAlignment="Center"
                                         Style="{StaticResource MaterialDesignFilledTextBox}"
                                         materialDesign:HintAssist.Hint="Projects Parent Path"
                                         Text="{Binding Settings_RootProjectsPath}"/>
                                <Button Grid.Column="1" Margin="5,0" VerticalAlignment="Center"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                        ToolTip="Browse..."
                                        Command="{Binding BrowseCreateRootFolderCommand}">
                                    <materialDesign:PackIcon Kind="FolderOpenOutline" Height="26" Width="26"/>
                                </Button>
                                <TextBox Grid.Column="2" Margin="10,0,5,0" VerticalAlignment="Center"
                                         Style="{StaticResource MaterialDesignFilledTextBox}"
                                         materialDesign:HintAssist.Hint="Company Name"
                                         Text="{Binding Settings_CreateCompanyName}" TextWrapping="Wrap"/>
                                <TextBox Grid.Column="3" Margin="5,0,0,0" VerticalAlignment="Center"
                                         Style="{StaticResource MaterialDesignFilledTextBox}"
                                         materialDesign:HintAssist.Hint="Project Name"
                                         Text="{Binding CreateProjectName, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap" x:Name="CreateProjectName" IsEnabled="True"/>
                            </Grid>

                            <!-- Row 1: Version & options (fills remaining space) -->
                            <uc:VersionAndOptionUserControl Grid.Row="1" VerticalAlignment="Stretch" x:Name="CreateVersionAndOption" Margin="0,10,0,0"/>

                            <!-- Row 2: Create button (end of flow, bottom-right) -->
                            <Button Grid.Row="2" Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                    Foreground="White"
                                    Height="50" Width="180" Content="Create" FontSize="16"
                                    HorizontalAlignment="Right" Margin="0,16,0,16"
                                    Command="{Binding CreateProjectCommand}"
                                    IsEnabled="{Binding IsFeatureConfigValid, ElementName=CreateVersionAndOption}"/>
                        </Grid>
                    </Grid>
                    <!--#endregion-->

                    <!--#region Migration Page -->
                    <uc:ModifyProjectUC x:Name="ModifyProject" Visibility="{Binding DataContext.SelectedPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Migration, FallbackValue=Collapsed}"/>
                    <!--#endregion-->

                    <!--#region Generation Page -->
                    <uc:GenerateUC x:Name="GenerateProject" Visibility="{Binding DataContext.SelectedPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Generation, FallbackValue=Collapsed}"/>
                    <!--#endregion-->

                </Grid>
            </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Row 2: Output Panel (collapsible) -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!-- OUTPUT header (always visible, clickable to toggle) -->
            <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    Cursor="Hand" MouseLeftButtonDown="ToggleOutputPanel">
                <Grid Height="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Grid.Column="0" Kind="ChevronRight"
                                             Width="16" Height="16" VerticalAlignment="Center" Margin="8,0,0,0"
                                             RenderTransformOrigin="0.5,0.5">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOutputExpanded}" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <RotateTransform Angle="90"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>

                    <Label Grid.Column="1" FontWeight="Bold" Content="OUTPUT" Padding="4,4"
                           FontSize="11" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Opacity="0.6"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button x:Name="StopButton" Command="{Binding StopActionCommand}"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="4" Width="28" Height="28" Margin="0,0,2,0"
                                ToolTip="Stop current action">
                            <materialDesign:PackIcon Kind="Stop" Width="16" Height="16" Foreground="IndianRed"/>
                        </Button>
                        <Button Command="{Binding ClearConsoleCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="4" Width="28" Height="28" Margin="0,0,2,0"
                                ToolTip="Clear console">
                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"/>
                        </Button>
                        <Button Command="{Binding CopyConsoleToClipboardCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="4" Width="28" Height="28"
                                ToolTip="Copy to clipboard">
                            <materialDesign:PackIcon Kind="ContentCopy" Width="16" Height="16"/>
                        </Button>
                        <Button Command="{Binding ToggleOutputMaximizedCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="4" Width="28" Height="28" Margin="2,0,0,0"
                                ToolTip="Maximize / Restore output panel">
                            <materialDesign:PackIcon Width="16" Height="16">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Kind" Value="ArrowExpand"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOutputMaximized}" Value="True">
                                                <Setter Property="Kind" Value="ArrowCollapse"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Console output (collapsible, selectable) -->
            <RichTextBox Grid.Row="1" Name="OutputRichTextBox"
                         Visibility="{Binding IsOutputExpanded, Converter={StaticResource BoolToVisConverter}}"
                         IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         BorderThickness="0" Padding="5"
                         FontFamily="Consolas"
                         Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                         Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <RichTextBox.Style>
                    <Style TargetType="RichTextBox">
                        <Setter Property="MaxHeight" Value="200"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOutputMaximized}" Value="True">
                                <Setter Property="MaxHeight" Value="{x:Static sys:Double.PositiveInfinity}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </RichTextBox.Style>
                <RichTextBox.Document>
                    <FlowDocument PagePadding="0"/>
                </RichTextBox.Document>
            </RichTextBox>
        </Grid>

        <!-- Waiter overlay: dim covers content only (output stays readable),
             loader stays centered across the full window (content + output). -->
        <Grid x:Name="WaiterDim" Grid.Row="1" IsHitTestVisible="{Binding IsBusy}"
              Background="{DynamicResource MaterialDesign.Brush.Card.Background}" Opacity="0.7"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}" d:Visibility="Hidden"/>
        <Grid x:Name="Waiter" Grid.Row="1" Grid.RowSpan="2" IsHitTestVisible="False"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}" d:Visibility="Hidden">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="True">
                <uc:PixelLeafLoaderUC Height="200" Width="200"/>
                <uc:PixelStopButtonUC Width="160" Height="50" Margin="0,40,0,0"
                                      Command="{Binding StopActionCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
    </materialDesign:DialogHost>
</Window>
