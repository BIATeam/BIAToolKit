<UserControl x:Class="BIA.ToolKit.UserControls.ProjectSelectorUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BIA.ToolKit.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProjectViewModel, IsDesignTimeCreatable=False}"
             d:Width="1280">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Root path + browse -->
        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <TextBox x:Name="RootPathTextBox"
                     Grid.Column="0"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     materialDesign:HintAssist.Hint="Projects Parent Path"
                     Text="{Binding RootProjectsPath}"
                     TextWrapping="Wrap"/>
            <Button Grid.Column="1" Margin="5,0"
                    Style="{StaticResource MaterialDesignIconButton}"
                    Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                    ToolTip="Browse..."
                    Click="BrowseRootFolder_Click">
                <materialDesign:PackIcon Kind="FolderOpenOutline" Height="26" Width="26"/>
            </Button>
        </Grid>

        <!-- Column 1: Project folder combo + refresh + refresh info -->
        <Grid Grid.Column="1" Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <ComboBox Grid.Column="0"
                      Style="{StaticResource MaterialDesignFilledComboBox}"
                      materialDesign:HintAssist.Hint="Project Folder"
                      ItemsSource="{Binding Projects}"
                      SelectedValue="{Binding Folder}"/>
            <Button Grid.Column="1" Command="{Binding RefreshProjetsListCommand}"
                    Style="{StaticResource MaterialDesignIconButton}"
                    Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                    ToolTip="Refresh project folder list" Margin="5,0">
                <materialDesign:PackIcon Kind="Refresh" Height="26" Width="26"/>
            </Button>
            <Button Style="{StaticResource MaterialDesignPaperDarkButton}"
                    Margin="0,5,0,0" Grid.Row="1"
                    IsEnabled="{Binding IsProjectSelected}"
                    Command="{Binding RefreshProjectInformationsCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Refresh project informations" VerticalAlignment="Center"/>
                    <materialDesign:PackIcon Margin="5,0,0,0" Kind="CogRefreshOutline" VerticalAlignment="Center" Height="20" Width="20"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Column 2: Read-only project info -->
        <Grid Grid.Column="2" Margin="10,0,0,0" IsEnabled="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="0.4*"/>
                </Grid.ColumnDefinitions>
                <TextBox FontSize="12" Grid.Column="0"
                         Style="{StaticResource MaterialDesignFilledTextBox}"
                         materialDesign:HintAssist.Hint="Company"
                         Text="{Binding CompanyName, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap"/>
                <TextBox FontSize="12" Grid.Column="1" Margin="5,0"
                         Style="{StaticResource MaterialDesignFilledTextBox}"
                         materialDesign:HintAssist.Hint="Project"
                         Text="{Binding Name, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap"/>
                <TextBox FontSize="12" Grid.Column="2"
                         Style="{StaticResource MaterialDesignFilledTextBox}"
                         materialDesign:HintAssist.Hint="Version"
                         Text="{Binding FrameworkVersion, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap"/>
            </Grid>
            <Grid Grid.Row="1" Margin="0,5,0,0">
                <TextBox FontSize="12"
                         Style="{StaticResource MaterialDesignFilledTextBox}"
                         materialDesign:HintAssist.Hint="BIA Front Folders"
                         Text="{Binding BIAFronts, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
