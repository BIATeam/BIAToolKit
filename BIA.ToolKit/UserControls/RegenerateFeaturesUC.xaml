<UserControl x:Class="BIA.ToolKit.UserControls.RegenerateFeaturesUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BIA.ToolKit.Application.ViewModel;assembly=BIA.ToolKit.Application"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1280">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Two-panel area -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel: generated features by entity ──────────────── -->
            <GroupBox Grid.Column="0" Header="Generated features" Foreground="White"
                      Style="{StaticResource MaterialDesignGroupBox}"
                      materialDesign:ColorZoneAssist.Mode="Custom"
                      materialDesign:ColorZoneAssist.Background="#608000"
                      materialDesign:ColorZoneAssist.Foreground="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column headers -->
                    <Grid Grid.Row="0" Margin="5,4,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Entity" Foreground="White" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="CRUD" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Option" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="DTO" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- No entities message -->
                    <TextBlock Grid.Row="1" Margin="10" Visibility="{Binding NoEntities, Converter={StaticResource BoolToVisConverter}}"
                               Text="No features found that can be regenerated." Foreground="LightGray" FontStyle="Italic" VerticalAlignment="Top"/>

                    <!-- Entity rows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding EntityRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#404040" BorderThickness="0,0,0,1" Padding="5,4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Entity name with select-all checkbox (row 0) -->
                                            <CheckBox Grid.Row="0" Grid.Column="0"
                                                      Foreground="White" FontWeight="Bold"
                                                      Content="{Binding EntityNameSingular}"
                                                      IsChecked="{Binding IsEntitySelected}"
                                                      VerticalAlignment="Center"/>

                                            <!-- CRUD checkbox -->
                                            <CheckBox Grid.Row="0" Grid.Column="1"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Foreground="White"
                                                      IsChecked="{Binding IsCrudSelected, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsCrudEnabled}"
                                                      Visibility="{Binding HasCrud, Converter={StaticResource BoolToVisConverter}}"/>

                                            <!-- Option checkbox -->
                                            <CheckBox Grid.Row="0" Grid.Column="2"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Foreground="White"
                                                      IsChecked="{Binding IsOptionSelected, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsOptionEnabled}"
                                                      Visibility="{Binding HasOption, Converter={StaticResource BoolToVisConverter}}"/>

                                            <!-- DTO checkbox -->
                                            <CheckBox Grid.Row="0" Grid.Column="3"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Foreground="White"
                                                      IsChecked="{Binding IsDtoSelected, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsDtoEnabled}"
                                                      Visibility="{Binding HasDto, Converter={StaticResource BoolToVisConverter}}"/>

                                            <!-- CRUD from version (row 1) -->
                                            <Grid Grid.Row="1" Grid.Column="1" Margin="2,2,2,0"
                                                  Visibility="{Binding HasCrud, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock Text="{Binding CrudStoredVersion}" Foreground="LightGray" FontSize="10" HorizontalAlignment="Center"
                                                           Visibility="{Binding IsCrudVersionStoredInHistory, Converter={StaticResource BoolToVisConverter}}"
                                                           ToolTip="Framework version at generation time"/>
                                                <ComboBox ItemsSource="{Binding AvailableVersions}"
                                                          SelectedItem="{Binding CrudVersionOverride, Mode=TwoWay}"
                                                          FontSize="10" Width="72"
                                                          materialDesign:HintAssist.Hint="From ver."
                                                          Style="{StaticResource MaterialDesignComboBox}"
                                                          Foreground="LightGray"
                                                          Visibility="{Binding IsCrudVersionNotStoredInHistory, Converter={StaticResource BoolToVisConverter}}"
                                                          ToolTip="Select the framework version used at generation time"/>
                                            </Grid>

                                            <!-- Option from version (row 2) -->
                                            <Grid Grid.Row="1" Grid.Column="2" Margin="2,2,2,0"
                                                  Visibility="{Binding HasOption, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock Text="{Binding OptionStoredVersion}" Foreground="LightGray" FontSize="10" HorizontalAlignment="Center"
                                                           Visibility="{Binding IsOptionVersionStoredInHistory, Converter={StaticResource BoolToVisConverter}}"
                                                           ToolTip="Framework version at generation time"/>
                                                <ComboBox ItemsSource="{Binding AvailableVersions}"
                                                          SelectedItem="{Binding OptionVersionOverride, Mode=TwoWay}"
                                                          FontSize="10" Width="72"
                                                          materialDesign:HintAssist.Hint="From ver."
                                                          Style="{StaticResource MaterialDesignComboBox}"
                                                          Foreground="LightGray"
                                                          Visibility="{Binding IsOptionVersionNotStoredInHistory, Converter={StaticResource BoolToVisConverter}}"
                                                          ToolTip="Select the framework version used at generation time"/>
                                            </Grid>

                                            <!-- DTO from version (row 3) -->
                                            <Grid Grid.Row="1" Grid.Column="3" Margin="2,2,2,0"
                                                  Visibility="{Binding HasDto, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock Text="{Binding DtoStoredVersion}" Foreground="LightGray" FontSize="10" HorizontalAlignment="Center"
                                                           Visibility="{Binding IsDtoVersionStoredInHistory, Converter={StaticResource BoolToVisConverter}}"
                                                           ToolTip="Framework version at generation time"/>
                                                <ComboBox ItemsSource="{Binding AvailableVersions}"
                                                          SelectedItem="{Binding DtoVersionOverride, Mode=TwoWay}"
                                                          FontSize="10" Width="72"
                                                          materialDesign:HintAssist.Hint="From ver."
                                                          Style="{StaticResource MaterialDesignComboBox}"
                                                          Foreground="LightGray"
                                                          Visibility="{Binding IsDtoVersionNotStoredInHistory, Converter={StaticResource BoolToVisConverter}}"
                                                          ToolTip="Select the framework version used at generation time"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="#404040"/>

            <!-- ── Right panel: summary ────────────────────────────────── -->
            <GroupBox Grid.Column="2" Header="Selected for regeneration" Foreground="White"
                      Style="{StaticResource MaterialDesignGroupBox}"
                      materialDesign:ColorZoneAssist.Mode="Custom"
                      materialDesign:ColorZoneAssist.Background="#608000"
                      materialDesign:ColorZoneAssist.Foreground="White">
                <DataGrid ItemsSource="{Binding SelectedFeatures}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          Background="#323232"
                          Foreground="White"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#404040"
                          RowBackground="#2A2A2A"
                          AlternatingRowBackground="#303030"
                          materialDesign:DataGridAssist.CellPadding="8 4"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="8 4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Entity" Binding="{Binding EntityNameSingular}" Width="*"/>
                        <DataGridTextColumn Header="Feature" Binding="{Binding FeatureType}" Width="70"/>
                        <DataGridTextColumn Header="From version" Binding="{Binding FromVersion}" Width="90"/>
                        <DataGridTextColumn Header="To version" Binding="{Binding ToVersion}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- ── Action buttons ─────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="ReloadButton"
                    Content="Reload"
                    Margin="0,0,10,0"
                    Click="Reload_Click"/>
            <Button x:Name="RegenerateButton"
                    Style="{StaticResource MaterialDesignRaisedSecondaryDarkButton}"
                    Content="Regenerate selected features"
                    Height="40"
                    IsEnabled="{Binding HasSelectedFeatures}"
                    Click="Regenerate_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
