<UserControl x:Class="BIA.ToolKit.UserControls.RegenerateFeaturesUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BIA.ToolKit.Application.ViewModel;assembly=BIA.ToolKit.Application"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.DataContext>
        <local:RegenerateFeaturesViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Top info panel -->
        <GroupBox Grid.Row="0" Header="Regenerate Features" Margin="0,0,0,5"
                  Style="{StaticResource MaterialDesignGroupBox}"
                  materialDesign:ColorZoneAssist.Mode="Custom"
                  materialDesign:ColorZoneAssist.Background="#608000"
                  materialDesign:ColorZoneAssist.Foreground="White"
                  Foreground="White">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Foreground="White" TextWrapping="Wrap"
                           Text="Regenerate previously created CRUD, Option, and DTO features based on generation history."/>
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Foreground="White" VerticalAlignment="Center">
                            <Run Text="Available entities: "/>
                            <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                            <Run Text=" | Ready: "/>
                            <Run Text="{Binding ReadyCount, Mode=OneWay}"/>
                            <Run Text=" | Issues: "/>
                            <Run Text="{Binding IssueCount, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Margin="5,0" Content="Select All" x:Name="SelectAllButton" Click="SelectAll_Click"
                                IsEnabled="{Binding HasReadyEntities}"/>
                        <Button Margin="5,0" Content="Deselect All" x:Name="DeselectAllButton" Click="DeselectAll_Click"
                                IsEnabled="{Binding HasReadyEntities}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Entity list -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="EntitiesItemsControl" ItemsSource="{Binding Entities}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="8,6">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Entity selection checkbox -->
                                        <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanSelectEntity}"
                                                  Click="EntityCheckBox_Click"/>
                                        <!-- Entity name -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontWeight="Bold" Text="{Binding EntityNameSingular}"/>
                                            <TextBlock FontSize="11" Foreground="Gray" Text="{Binding EntityNamePlural}"/>
                                        </StackPanel>
                                        <!-- CRUD indicator -->
                                        <Border Grid.Column="2" Margin="2" CornerRadius="3" Padding="4,2"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding HasCrudHistory, Converter={StaticResource BoolToVisConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CrudStatus}" Value="Ready">
                                                            <Setter Property="Background" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CrudStatus}" Value="Missing">
                                                            <Setter Property="Background" Value="#F44336"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CrudStatus}" Value="Error">
                                                            <Setter Property="Background" Value="#FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Background" Value="Gray"/>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Foreground="White" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CrudStatus}" Value="Ready">
                                                                <Setter Property="Text" Value="✓ CRUD"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CrudStatus}" Value="Missing">
                                                                <Setter Property="Text" Value="❌ CRUD"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CrudStatus}" Value="Error">
                                                                <Setter Property="Text" Value="⚠ CRUD"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                        <Setter Property="Text" Value="- CRUD"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <!-- Option indicator -->
                                        <Border Grid.Column="3" Margin="2" CornerRadius="3" Padding="4,2"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding HasOptionHistory, Converter={StaticResource BoolToVisConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OptionStatus}" Value="Ready">
                                                            <Setter Property="Background" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OptionStatus}" Value="Missing">
                                                            <Setter Property="Background" Value="#F44336"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OptionStatus}" Value="Error">
                                                            <Setter Property="Background" Value="#FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Background" Value="Gray"/>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Foreground="White" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OptionStatus}" Value="Ready">
                                                                <Setter Property="Text" Value="✓ Option"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding OptionStatus}" Value="Missing">
                                                                <Setter Property="Text" Value="❌ Option"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding OptionStatus}" Value="Error">
                                                                <Setter Property="Text" Value="⚠ Option"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                        <Setter Property="Text" Value="- Option"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <!-- DTO indicator -->
                                        <Border Grid.Column="4" Margin="2" CornerRadius="3" Padding="4,2"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding HasDtoHistory, Converter={StaticResource BoolToVisConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DtoStatus}" Value="Ready">
                                                            <Setter Property="Background" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DtoStatus}" Value="Missing">
                                                            <Setter Property="Background" Value="#F44336"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DtoStatus}" Value="Error">
                                                            <Setter Property="Background" Value="#FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Background" Value="Gray"/>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Foreground="White" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DtoStatus}" Value="Ready">
                                                                <Setter Property="Text" Value="✓ DTO"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DtoStatus}" Value="Missing">
                                                                <Setter Property="Text" Value="❌ DTO"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DtoStatus}" Value="Error">
                                                                <Setter Property="Text" Value="⚠ DTO"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                        <Setter Property="Text" Value="- DTO"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <!-- Last generation date -->
                                        <TextBlock Grid.Column="5" VerticalAlignment="Center" Foreground="Gray" FontSize="11"
                                                   Text="{Binding LastGenerationDate, StringFormat={}{0:yyyy-MM-dd}}" Margin="5,0"/>
                                        <!-- Status badge -->
                                        <Border Grid.Column="6" Margin="2" CornerRadius="3" Padding="4,2" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FF9800"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAnyIssue}" Value="False">
                                                            <Setter Property="Background" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Foreground="White" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="⚠ Issues"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasAnyIssue}" Value="False">
                                                                <Setter Property="Text" Value="✓ Ready"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                    <!-- Issue details row (visible only when there are issues) -->
                                    <StackPanel Margin="30,4,0,0"
                                                Visibility="{Binding HasAnyIssue, Converter={StaticResource BoolToVisConverter}}">
                                        <TextBlock FontSize="11" Foreground="#FF9800">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CrudStatus}" Value="Missing">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CrudStatus}" Value="Error">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="  CRUD: "/>
                                            <Run Text="{Binding CrudHistory.Mapping.Dto, StringFormat=DTO file not found: {0}}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="#FF9800">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OptionStatus}" Value="Missing">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OptionStatus}" Value="Error">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="  Option: "/>
                                            <Run Text="{Binding OptionHistory.Mapping.Entity, StringFormat=Entity file not found: {0}}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="#FF9800">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DtoStatus}" Value="Missing">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DtoStatus}" Value="Error">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="  DTO: "/>
                                            <Run Text="{Binding EntityNameSingular, StringFormat=DTO file not found: {0}Dto.cs}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Feature selection checkboxes -->
        <GroupBox Grid.Row="2" Header="Features to regenerate" Margin="0,0,0,5"
                  Style="{StaticResource MaterialDesignGroupBox}"
                  materialDesign:ColorZoneAssist.Mode="Custom"
                  materialDesign:ColorZoneAssist.Background="#404040"
                  materialDesign:ColorZoneAssist.Foreground="White"
                  Foreground="White">
            <StackPanel Orientation="Horizontal" Margin="5">
                <CheckBox x:Name="RegenerateCrudCheckBox" Content="Regenerate CRUD" Margin="10,0"
                          Foreground="White" IsChecked="{Binding RegenerateCrud, Mode=TwoWay}"/>
                <CheckBox x:Name="RegenerateOptionCheckBox" Content="Regenerate Option" Margin="10,0"
                          Foreground="White" IsChecked="{Binding RegenerateOption, Mode=TwoWay}"/>
                <CheckBox x:Name="RegenerateDtoCheckBox" Content="Regenerate DTO" Margin="10,0"
                          Foreground="White" IsChecked="{Binding RegenerateDto, Mode=TwoWay}"/>
            </StackPanel>
        </GroupBox>

        <!-- Action buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="CANCEL" Margin="5,0" Click="Cancel_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
            <Button Grid.Column="2" Content="REGENERATE" Margin="5,0" Click="Regenerate_Click"
                    IsEnabled="{Binding IsRegenerateEnabled}"
                    Style="{StaticResource MaterialDesignRaisedSecondaryDarkButton}"/>
        </Grid>
    </Grid>
</UserControl>
