<UserControl x:Class="BIA.ToolKit.UserControls.FeaturePreviewVideo"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border x:Name="Container"
            Visibility="Collapsed"
            CornerRadius="4"
            BorderThickness="1"
            BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}"
            Background="Black"
            Margin="0,8,0,0"
            ClipToBounds="True">
        <Grid MinHeight="140">
            <MediaElement x:Name="PreviewMedia"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Manual"
                          IsMuted="True"
                          Stretch="Uniform"
                          ScrubbingEnabled="True"
                          MediaOpened="Media_OnOpened"
                          MediaEnded="Media_OnEnded"
                          MediaFailed="Media_OnFailed"
                          Loaded="Media_OnLoaded"
                          Unloaded="Media_OnUnloaded"/>
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6"
                    Padding="5,2" CornerRadius="3" Background="#CC000000">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="#E53935" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="LIVE DEMO" FontSize="9" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
