<UserControl x:Class="BIA.ToolKit.UserControls.OptionGeneratorUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BIA.ToolKit.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:OptionGeneratorViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldHelpStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
        </Style>

        <Style x:Key="FeatureTileStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="FeatureTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FeatureDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.75"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="RootScrollViewer" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="10,10,10,0"
                      RequestBringIntoView="RootScrollViewer_RequestBringIntoView">
            <StackPanel>

                <!-- ================= Section 1 : Source de l'entité ================= -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="① SOURCE DE L'ENTITÉ"/>
                        <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                                   Text="Sélectionne l'entité Option à générer et sa configuration de base."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <!-- Option Entity -->
                            <StackPanel Grid.Column="0" Grid.Row="0">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="Option Entity"
                                          ItemsSource="{Binding Entities}" SelectedItem="{Binding Entity, Mode=TwoWay}"
                                          IsEnabled="{Binding IsProjectChosen}"
                                          ItemTemplate="{StaticResource EntityDisplayTemplate}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="SelectionChanged">
                                            <i:InvokeCommandAction Command="{Binding EntitySelectionChangedCommand}"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ComboBox>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Classe C# qui sera transformée en liste déroulante (dropdown). Typiquement une entité avec un Id et un Display."/>
                            </StackPanel>

                            <!-- Domain -->
                            <StackPanel Grid.Column="2" Grid.Row="0">
                                <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                         materialDesign:HintAssist.Hint="Domain"
                                         Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                         IsEnabled="{Binding IsEntityParsed}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Dossier métier où ranger les fichiers générés (déduit du namespace)."/>
                            </StackPanel>

                            <!-- BIA Front -->
                            <StackPanel Grid.Column="4" Grid.Row="0">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="BIA Front"
                                          ItemsSource="{Binding BiaFronts}"
                                          SelectedValue="{Binding BiaFront, Mode=TwoWay}"
                                          IsEnabled="{Binding IsProjectChosen}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="SelectionChanged">
                                            <i:InvokeCommandAction Command="{Binding BiaFrontSelectionChangedCommand}" CommandParameter="{Binding BiaFront}"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ComboBox>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Front-end Angular cible. Laisse vide pour générer uniquement le back."/>
                            </StackPanel>

                            <!-- Generation-already-done warning -->
                            <Label Grid.Row="1" Grid.ColumnSpan="5" Margin="0,6,0,0"
                                   Name="OptionAlreadyGeneratedLabel"
                                   Content="⚠ Une génération a déjà été faite pour cette entité"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                   FontWeight="SemiBold"
                                   Visibility="Collapsed" d:Visibility="Visible"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ================= Section 2 : Nom & affichage ================= -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="② NOM &amp; AFFICHAGE"/>
                        <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                                   Text="Comment l'option est nommée dans le code et quelle propriété est affichée dans la dropdown."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Entity Name Plural -->
                            <StackPanel Grid.Column="0">
                                <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                         materialDesign:HintAssist.Hint="Entity Name Plural"
                                         Text="{Binding EntityNamePlural, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                         IsEnabled="{Binding IsEntityParsed}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Nom au pluriel de l'entité (ex: Countries, Languages). Utilisé pour les routes et noms de collections."/>
                            </StackPanel>

                            <!-- Option Display Property -->
                            <StackPanel Grid.Column="2">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="Option Display Property"
                                          ItemsSource="{Binding EntityDisplayItems}"
                                          SelectedValue="{Binding EntityDisplayItemSelected}"
                                          IsEnabled="{Binding IsEntityParsed}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Propriété texte affichée dans la dropdown (ex: Name, Label, Title)."/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ================= Section 3 : Features (V7+ only) ================= -->
                <Border Style="{StaticResource SectionCardStyle}"
                        Visibility="{Binding IsProjectCompatibleV7, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="③ FEATURES"/>
                        <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                                   Text="Options de génération avancées disponibles pour cette version du framework."/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Use HUB client -->
                            <Border Grid.Column="0">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UseHubClient}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding UseHubClient}" IsEnabled="{Binding IsProjectChosen}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Hub client (SignalR)"/>
                                            <Border Margin="8,0,0,0" Padding="4,1" CornerRadius="3"
                                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="V7+" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </CheckBox>
                                    <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                               Text="Génère un hub SignalR côté back et le client Angular associé pour des mises à jour temps réel de la liste d'options."/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Row 1: Footer — actions -->
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="DeleteAnnotations"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0" Padding="10,4" MinWidth="0"
                            Command="{Binding DeleteBIAToolkitAnnotationsCommand}"
                            IsEnabled="{Binding IsProjectChosen}"
                            ToolTip="Supprime les marqueurs BIAToolkit présents dans le code (irréversible).">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TagRemoveOutline" Height="16" Width="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Delete annotations" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="GenerateOption"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Foreground="White"
                            Height="40" Padding="16,0" MinWidth="150"
                            Command="{Binding GenerateCommand}"
                            IsEnabled="{Binding IsButtonGenerateOptionEnable}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="FlashOutline" Height="20" Width="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Générer" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
