<UserControl x:Class="BIA.ToolKit.UserControls.CRUDGeneratorUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BIA.ToolKit.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CRUDGeneratorViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="900" d:DesignWidth="1200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <!-- Section card: outer container for each numbered section. -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Section header: small primary-colored uppercase label "① TITLE". -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- Section subtitle: one-line description under the section header. -->
        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Micro-description below a field label (Level 2 pedagogy). -->
        <Style x:Key="FieldHelpStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
        </Style>

        <!-- Base feature tile (inactive look). Active look is set per-tile via DataTrigger
             on the feature's own bool property (see each tile below). -->
        <Style x:Key="FeatureTileStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Feature title (inside a tile). -->
        <Style x:Key="FeatureTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Feature description (always visible, no hover needed). -->
        <Style x:Key="FeatureDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.75"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <!-- Sub-parameter label inside an expanded feature tile. -->
        <Style x:Key="SubFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.85"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <!-- Preview panel ("⚡ What will be generated ...") -->
        <Style x:Key="PreviewBoxStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Background}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="PreviewLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </Style>

        <Style x:Key="PreviewValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Target toggle card (Web API / Angular Front). Border styled with triggers
             on a ToggleButton's IsChecked so clicking the surface toggles the value. -->
        <Style x:Key="TargetCardToggleStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="CardBorder"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}"
                                Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                            <ContentPresenter Margin="14,12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush"
                                        Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush"
                                        Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab header with badge counter (e.g. "🔐 Access (2)"). -->
        <DataTemplate x:Key="TabHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Title}" FontSize="12"/>
                <Border Margin="6,0,0,0" Padding="5,1"
                        CornerRadius="8"
                        Background="{DynamicResource MaterialDesign.Brush.Primary}"
                        Visibility="{Binding HasBadge, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="{Binding Count}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: scrollable body with sectioned cards -->
        <ScrollViewer x:Name="RootScrollViewer" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="10,10,10,0"
                      RequestBringIntoView="RootScrollViewer_RequestBringIntoView">
            <StackPanel>

                <!-- ================= Section ① Entity source ================= -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="① ENTITY SOURCE"/>
                        <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                                   Text="Where the entity to generate comes from and what kind of code to produce."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.4*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <!-- DTO Entity File -->
                            <StackPanel Grid.Column="0" Grid.Row="0">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="DTO Entity File"
                                          ItemsSource="{Binding DtoEntities}" SelectedItem="{Binding DtoEntity}"
                                          IsEnabled="{Binding IsProjectChosen}"
                                          ItemTemplate="{StaticResource EntityDisplayTemplate}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Source DTO file: fields, name and domain are derived from this file."/>
                            </StackPanel>

                            <!-- Generation (Feature to generate) -->
                            <StackPanel Grid.Column="2" Grid.Row="0">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="Feature to generate"
                                          ItemsSource="{Binding FeatureNames}" SelectedItem="{Binding FeatureNameSelected}"
                                          IsEnabled="{Binding IsDtoParsed}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Generation type: full CRUD, Option, Team..."/>
                            </StackPanel>

                            <!-- Base Key Type -->
                            <StackPanel Grid.Column="4" Grid.Row="0">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="Base Key Type"
                                          ItemsSource="{Binding BaseKeyTypeItems}"
                                          SelectedValue="{Binding SelectedBaseKeyType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                          IsEnabled="{Binding IsDtoParsed}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Primary key type (int, long, Guid...)."/>
                            </StackPanel>

                            <!-- Domain -->
                            <StackPanel Grid.Column="6" Grid.Row="0">
                                <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                         materialDesign:HintAssist.Hint="Domain"
                                         Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsDtoParsed}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Business folder where generated files will be placed (derived from namespace)."/>
                            </StackPanel>

                            <!-- Generation-already-done warning, full width -->
                            <Border Grid.Row="1" Grid.ColumnSpan="7" Margin="0,8,0,0"
                                    Padding="10,8" CornerRadius="4"
                                    Background="#33FF8C00"
                                    BorderBrush="Orange" BorderThickness="1"
                                    Visibility="{Binding IsDtoGenerated, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertOutline" Height="18" Width="18"
                                                             Foreground="Orange" VerticalAlignment="Center"/>
                                    <TextBlock Text="A generation has already been performed for this entity"
                                               Foreground="Orange" FontWeight="SemiBold" FontSize="12"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ================= Section ② Name & display ================= -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="② ENTITY NAME &amp; DISPLAY"/>
                        <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                                   Text="How the entity is named in code and displayed in the UI."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <!-- Singular -->
                            <StackPanel Grid.Column="0">
                                <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                         materialDesign:HintAssist.Hint="Name (singular)"
                                         Text="{Binding CRUDNameSingular, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsDtoParsed}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Singular entity name (e.g. Plane, Product). Used as-is in C# classes and Angular components."/>
                            </StackPanel>

                            <!-- Plural -->
                            <StackPanel Grid.Column="2">
                                <Grid>
                                    <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                             materialDesign:HintAssist.Hint="Plural"
                                             Text="{Binding CRUDNamePlural, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsDtoParsed}"/>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,6,8,0" Padding="4,1" CornerRadius="3"
                                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                            Visibility="{Binding IsPluralAutoDerived, Converter={StaticResource BoolToVisConverter}}">
                                        <TextBlock Text="auto" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </Grid>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Auto-derived from singular via Humanizer. Edit it if the generated plural isn't correct."/>
                            </StackPanel>

                            <!-- Display property -->
                            <StackPanel Grid.Column="4">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="Display property"
                                          ItemsSource="{Binding DtoDisplayItems}"
                                          SelectedValue="{Binding DtoDisplayItemSelected}"
                                          IsEnabled="{Binding IsDtoParsed}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Property used in lists/parent screens to identify the row (e.g. Name, Title)."/>
                            </StackPanel>

                            <!-- Option items -->
                            <StackPanel Grid.Column="6">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="Linked options"
                                          ItemsSource="{Binding OptionItems}"
                                          IsEnabled="{Binding IsOptionItemEnable}"
                                          Text="{Binding SelectedOptionItems, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True" IsReadOnly="True">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding OptionName}" IsChecked="{Binding Check}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="Existing options (dropdowns) that can be referenced by this entity."/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ================= Section ③ Generation target ================= -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="③ GENERATION TARGET"/>
                        <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                                   Text="Which layers to generate. You can tick one or both."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Web API card -->
                            <ToggleButton Grid.Column="0"
                                          Style="{StaticResource TargetCardToggleStyle}"
                                          IsChecked="{Binding IsWebApiSelected}"
                                          IsEnabled="{Binding IsWebApiAvailable}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" VerticalAlignment="Center"
                                            Background="{DynamicResource MaterialDesign.Brush.Primary}">
                                        <materialDesign:PackIcon Kind="Api" Height="20" Width="20"
                                                                 Foreground="White"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Web API (Back)" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Controller, Service, DTO, Repository"
                                                   Style="{StaticResource FeatureDescriptionStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <materialDesign:PackIcon Grid.Column="2" VerticalAlignment="Center"
                                                             Kind="CheckboxMarkedCircle" Height="22" Width="22"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                             Visibility="{Binding IsWebApiSelected, Converter={StaticResource BoolToVisConverter}}"/>
                                </Grid>
                            </ToggleButton>

                            <!-- Angular Front card -->
                            <ToggleButton Grid.Column="2"
                                          Style="{StaticResource TargetCardToggleStyle}"
                                          IsChecked="{Binding IsFrontSelected}"
                                          IsEnabled="{Binding IsFrontAvailable}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" VerticalAlignment="Center"
                                            Background="{DynamicResource MaterialDesign.Brush.Primary}">
                                        <materialDesign:PackIcon Kind="Angular" Height="20" Width="20"
                                                                 Foreground="White"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Angular Front" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Pages, Routes, Form, Store NgRx"
                                                   Style="{StaticResource FeatureDescriptionStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <materialDesign:PackIcon Grid.Column="2" VerticalAlignment="Center"
                                                             Kind="CheckboxMarkedCircle" Height="22" Width="22"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                             Visibility="{Binding IsFrontSelected, Converter={StaticResource BoolToVisConverter}}"/>
                                </Grid>
                            </ToggleButton>

                            <!-- BIA Front version -->
                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="BIA Front version"
                                          x:Name="BiaFront"
                                          ItemsSource="{Binding BiaFronts}"
                                          SelectedValue="{Binding BiaFront}"
                                          IsEnabled="{Binding IsFrontSelected}"/>
                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                           Text="BIA front-end version to use as target (required if Angular Front is ticked)."/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ================= Section ④ Features ================= -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="④ FEATURES"/>
                                <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                                           Text="Generation options, grouped by theme. A feature's parameters appear in its own tile when enabled."/>
                            </StackPanel>
                        </Grid>

                        <TabControl Background="Transparent"
                                    BorderThickness="0"
                                    IsEnabled="{Binding IsDtoParsed}">

                            <!-- ==== Tab: Lifecycle ==== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileDocumentMultipleOutline" Height="16" Width="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Lifecycle" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="8"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                Visibility="{Binding HasLifecycleActive, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="{Binding LifecycleActiveCount}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </TabItem.Header>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Versioned -->
                                    <Border Grid.Column="0" Grid.Row="0">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVersioned}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding IsVersioned}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Versioned"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Keeps a full history of all entity changes (who changed what, when)."/>
                                            <Border Style="{StaticResource PreviewBoxStyle}"
                                                    Visibility="{Binding IsVersioned, Converter={StaticResource BoolToVisConverter}}">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource PreviewLabelStyle}" Text="⚡ WHAT WILL BE GENERATED"/>
                                                    <TextBlock Style="{StaticResource PreviewValueStyle}">
                                                        <Run Text="→ table "/><Run Text="History_" FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/><Run Text="{Binding CRUDNameSingular, Mode=OneWay, FallbackValue=Entity}" FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/><Run Text=" created"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Archivable -->
                                    <Border Grid.Column="2" Grid.Row="0">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsArchivable}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding IsArchivable}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Archivable"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Logical deletion (soft-delete) instead of permanent removal. The row stays in the DB with an IsDeleted flag."/>
                                            <Border Style="{StaticResource PreviewBoxStyle}"
                                                    Visibility="{Binding IsArchivable, Converter={StaticResource BoolToVisConverter}}">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource PreviewLabelStyle}" Text="⚡ WHAT WILL BE GENERATED"/>
                                                    <TextBlock Style="{StaticResource PreviewValueStyle}"
                                                               Text="→ IsDeleted column added · Delete becomes UPDATE IsDeleted=true"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Fixable -->
                                    <Border Grid.Column="0" Grid.Row="2">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFixable}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding IsFixable}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Fixable (pinning)"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Lets the user pin a row at the top of the list (e.g. important entities always visible first)."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Display Historical (V6+) -->
                                    <Border Grid.Column="2" Grid.Row="2"
                                            Visibility="{Binding IsProjectCompatibleV6, Converter={StaticResource BoolToVisConverter}}">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplayHistorical}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding DisplayHistorical}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Show History"/>
                                                    <Border Margin="8,0,0,0" Padding="4,1" CornerRadius="3"
                                                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="V6+" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Shows the change timeline directly in the entity detail screen (requires Versioned)."/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- ==== Tab: Access ==== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ShieldAccountOutline" Height="16" Width="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Access" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="8"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                Visibility="{Binding HasAccessActive, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="{Binding AccessActiveCount}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </TabItem.Header>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Team -->
                                    <Border Grid.Column="0">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTeam}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding IsTeam, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding IsCheckBoxIsTeamEnable}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Team (access rights)"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="The entity belongs to a team. Users must be members of that team to access it (Admin / Member roles)."/>

                                            <!-- Expanded Team sub-parameters (only when IsTeam) -->
                                            <StackPanel Visibility="{Binding IsTeam, Converter={StaticResource BoolToVisConverter}}">
                                                <Border Margin="0,10,0,8" Height="1" Background="{DynamicResource MaterialDesign.Brush.Card.Border}"/>

                                                <!-- Only shown when UseFileGenerator is true (matches previous XAML) -->
                                                <StackPanel Visibility="{Binding UseFileGenerator, Converter={StaticResource BoolToVisConverter}}">
                                                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="TEAM PARAMETERS" Margin="0,0,0,6"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <materialDesign:NumericUpDown Style="{StaticResource MaterialDesignFilledNumericUpDown}"
                                                                                          materialDesign:HintAssist.Hint="Team Type ID"
                                                                                          Value="{Binding TeamTypeId}"/>
                                                            <TextBlock Style="{StaticResource FieldHelpStyle}"
                                                                       Text="ID in the TeamType table (e.g. 3 = Squad)."/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <materialDesign:NumericUpDown Style="{StaticResource MaterialDesignFilledNumericUpDown}"
                                                                                          materialDesign:HintAssist.Hint="Team Role Type ID"
                                                                                          Value="{Binding TeamRoleId}"/>
                                                            <TextBlock Style="{StaticResource FieldHelpStyle}"
                                                                       Text="ID in the RoleType table (e.g. 2 = Squad Role)."/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>

                                                <StackPanel Margin="0,8,0,0">
                                                    <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                                             materialDesign:HintAssist.Hint="Parent team type (optional)"
                                                             Text="{Binding AncestorTeam, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Style="{StaticResource FieldHelpStyle}"
                                                               Text="Parent team type from which this entity inherits in the hierarchy (e.g. Site). Leave empty if no inheritance."/>
                                                </StackPanel>

                                                <!-- Team roles preview -->
                                                <Border Style="{StaticResource PreviewBoxStyle}"
                                                        Visibility="{Binding HasTeamRolesPreview, Converter={StaticResource BoolToVisConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource PreviewLabelStyle}" Text="⚡ ROLES THAT WILL BE ADDED"/>
                                                        <TextBlock Style="{StaticResource PreviewValueStyle}" Text="{Binding TeamRolesPreview}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Form Read-Only -->
                                    <Border Grid.Column="2">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasFormReadOnlyMode}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding HasFormReadOnlyMode}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Read-only form"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Generates a read-only display mode of the entity form (e.g. for view-only consultations)."/>

                                            <StackPanel Visibility="{Binding HasFormReadOnlyMode, Converter={StaticResource BoolToVisConverter}}">
                                                <Border Margin="0,10,0,8" Height="1" Background="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
                                                <TextBlock Style="{StaticResource SubFieldLabelStyle}" Text="Mode"/>
                                                <TextBlock Style="{StaticResource FieldHelpStyle}"
                                                           Text="Choose between read-only everywhere or only on the detail page."/>
                                                <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                                          Margin="0,2,0,0"
                                                          ItemsSource="{Binding FormReadOnlyModes}"
                                                          SelectedValue="{Binding SelectedFormReadOnlyMode}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- ==== Tab: Relations ==== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="LinkVariant" Height="16" Width="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Relations" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="8"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                Visibility="{Binding HasRelationsActive, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="{Binding RelationsActiveCount}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </TabItem.Header>

                                <Grid Margin="0,10,0,0">
                                    <!-- Parent (HasParent) -->
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasParent}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding HasParent, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding IsCheckboxParentEnable}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Parent entity"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Indicates that this entity is attached to a parent entity (e.g. a Plane belongs to a Site). Parent Admin/Member roles are added to permissions."/>

                                            <StackPanel Visibility="{Binding HasParent, Converter={StaticResource BoolToVisConverter}}">
                                                <Border Margin="0,10,0,8" Height="1" Background="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                                                 materialDesign:HintAssist.Hint="Parent name (singular)"
                                                                 Text="{Binding ParentName, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Style="{StaticResource FieldHelpStyle}"
                                                                   Text="Parent entity name (e.g. Site, Airport)."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                                                 materialDesign:HintAssist.Hint="Plural"
                                                                 Text="{Binding ParentNamePlural, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Style="{StaticResource FieldHelpStyle}"
                                                                   Text="Parent plural (auto-derived, editable)."/>
                                                    </StackPanel>
                                                </Grid>

                                                <CheckBox Margin="0,8,0,0" IsChecked="{Binding HasFixableParent}">
                                                    <StackPanel>
                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Fixable Parent"/>
                                                        <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                                   Text="Lets the user pin a row at the parent level (useful for filtered views)."/>
                                                    </StackPanel>
                                                </CheckBox>

                                                <Border Style="{StaticResource PreviewBoxStyle}"
                                                        Visibility="{Binding HasParentRolesPreview, Converter={StaticResource BoolToVisConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource PreviewLabelStyle}" Text="⚡ ROLES THAT WILL BE ADDED"/>
                                                        <TextBlock Style="{StaticResource PreviewValueStyle}" Text="{Binding ParentRolesPreview}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- ==== Tab: Integrations ==== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PuzzleOutline" Height="16" Width="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Integrations" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="8"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                Visibility="{Binding HasIntegrationsActive, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="{Binding IntegrationsActiveCount}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </TabItem.Header>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Import -->
                                    <Border Grid.Column="0">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UseImport}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding UseImport}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Import"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Adds a CSV/Excel import endpoint on the API side and an ImportDialogComponent on the Angular side."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Hub Client -->
                                    <Border Grid.Column="2">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UseHubClient}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding UseHubClient}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Hub client (SignalR)"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Real-time sync: when a user edits a row, the other users see the change instantly."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Use Domain URL (V6+) -->
                                    <Border Grid.Column="4"
                                            Visibility="{Binding IsProjectCompatibleV6, Converter={StaticResource BoolToVisConverter}}">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UseDomainUrl}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding UseDomainUrl}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Domain URL"/>
                                                    <Border Margin="8,0,0,0" Padding="4,1" CornerRadius="3"
                                                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="V6+" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Prefixes generated URLs with the domain name (e.g. /products/planes instead of /planes)."/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- ==== Tab: Behavior ==== -->
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CogOutline" Height="16" Width="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Behavior" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="8"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                Visibility="{Binding HasBehaviorActive, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="{Binding BehaviorActiveCount}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </TabItem.Header>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Advanced Filter -->
                                    <Border Grid.Column="0">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UseAdvancedFilter}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding UseAdvancedFilter}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Advanced Filter"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Advanced search panel on the Angular side (multiple operators, per-column filters, saved filters)."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Custom Repository -->
                                    <Border Grid.Column="2">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCustomRepository}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding HasCustomRepository}">
                                                <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Custom Repository"/>
                                            </CheckBox>
                                            <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                                       Text="Generates a customizable Repository class where you can write specific EF queries (override of the generic Repository)."/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                        </TabControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Row 1: Footer — summary + secondary actions + primary Generate button -->
        <Border Grid.Row="1"
                Background="Transparent"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: summary + secondary actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ClipboardTextOutline" Height="18" Width="18" VerticalAlignment="Center" Opacity="0.6"/>
                    <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12">
                        <Run Text="Summary: "/>
                        <Run Text="{Binding GenerationSummary, Mode=OneWay}"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="DeleteGeneration"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0" Padding="10,4" MinWidth="0"
                            Command="{Binding DeleteLastGenerationCommand}"
                            IsEnabled="{Binding IsDtoParsed}"
                            ToolTipService.InitialShowDelay="200"
                            ToolTipService.ShowDuration="20000">
                        <Button.ToolTip>
                            <StackPanel Orientation="Vertical" MaxWidth="340">
                                <TextBlock FontWeight="SemiBold" Margin="0,0,0,4"
                                           Text="Revert the last generation"/>
                                <TextBlock TextWrapping="Wrap"
                                           Text="Deletes the produced files and removes the blocks inserted in shared files (routes, DI…) for this DTO."/>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" Opacity="0.75" FontStyle="Italic"
                                           Text="Warning: no git revert. Manual edits to generated files will be lost. A confirmation will be asked."/>
                            </StackPanel>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="UndoVariant" Height="16" Width="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Delete last generation" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="DeleteAnnotations"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0" Padding="10,4" MinWidth="0"
                            Command="{Binding DeleteBIAToolkitAnnotationsCommand}"
                            IsEnabled="{Binding IsProjectChosen}"
                            ToolTip="Removes BIAToolkit markers present in the code (irreversible).">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TagRemoveOutline" Height="16" Width="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Delete annotations" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="GenerateCrud"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Foreground="White"
                            Height="40" Padding="16,0" MinWidth="150"
                            Command="{Binding GenerateCommand}"
                            IsEnabled="{Binding IsButtonGenerateCrudEnable}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="FlashOutline" Height="20" Width="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Generate" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
