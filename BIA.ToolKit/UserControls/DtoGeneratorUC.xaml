<UserControl x:Class="BIA.ToolKit.UserControls.DtoGeneratorUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BIA.ToolKit.Application.Models.DtoGenerator;assembly=BIA.ToolKit.Application"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:BIA.ToolKit.Behaviors"
             xmlns:helpers="clr-namespace:BIA.ToolKit.Helper"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldHelpStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
        </Style>

        <Style x:Key="FeatureTileStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="FeatureTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FeatureDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </UserControl.Resources>

    <materialDesign:DrawerHost BorderThickness="0" IsEnabled="{Binding IsFileGeneratorInit}">
        <materialDesign:DrawerHost.RightDrawerContent>
            <!-- Reorder drawer: flat draggable list of mapped properties.
                 Placed at UserControl level so its height is bound to the visible
                 viewport (not the scrollable content), keeping Done visible. -->
            <Grid Width="380" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="SwapVertical" Height="20" Width="20" VerticalAlignment="Center"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="REORDER MAPPING" Margin="8,0,0,0"
                               Style="{StaticResource SectionHeaderStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Row="1"
                           Style="{StaticResource SectionSubtitleStyle}"
                           Text="Drag and drop to change the generation order of the mapped properties."/>

                <Button Grid.Row="2" Margin="0,0,0,12" HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{x:Static materialDesign:DrawerHost.CloseDrawerCommand}"
                        CommandParameter="{x:Static Dock.Right}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check" Height="16" Width="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Done" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Grid.Row="3" CornerRadius="4" BorderThickness="1"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}">
                    <ListView Name="PropertiesListView"
                              ItemsSource="{Binding MappingEntityProperties}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              BorderThickness="0">
                        <i:Interaction.Behaviors>
                            <behaviors:ListViewDragDropBehavior MoveCommand="{Binding MoveMappedPropertyCommand}"/>
                        </i:Interaction.Behaviors>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DragDropHelper.IsDropTarget)}" Value="True">
                                        <Setter Property="Background" Value="#595959"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Opacity="0.6" Width="15" Height="15"
                                           Source="/Images/drag_icon.png"
                                           RenderOptions.BitmapScalingMode="Fant"
                                           Cursor="SizeNS" Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown"
                                           MouseMove="DragHandle_MouseMove"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding EntityCompositeName}" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="→" Opacity="0.5" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding MappingName}" Opacity="0.8" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>
        </materialDesign:DrawerHost.RightDrawerContent>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
    <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- ================= Row 0: Config cards ================= -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Section 1: Entity source -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="① ENTITY SOURCE"/>
                    <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                               Text="Source entity for the DTO and its base configuration."/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <!-- Entity -->
                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                      materialDesign:HintAssist.Hint="Entity"
                                      x:Name="EntitiesComboBox"
                                      ItemsSource="{Binding Entities}"
                                      SelectedItem="{Binding Entity, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      IsEnabled="{Binding IsProjectChosen}"
                                      ItemTemplate="{StaticResource EntityDisplayTemplate}"/>
                            <TextBlock Style="{StaticResource FieldHelpStyle}"
                                       Text="Source C# class whose properties will be exposed in the DTO."/>
                        </StackPanel>

                        <!-- Base Key Type -->
                        <StackPanel Grid.Column="2" Grid.Row="0">
                            <ComboBox Style="{StaticResource MaterialDesignFilledComboBox}"
                                      materialDesign:HintAssist.Hint="Base Key Type"
                                      ItemsSource="{Binding BaseKeyTypeItems}"
                                      SelectedValue="{Binding SelectedBaseKeyType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      IsEnabled="{Binding IsEntitySelected}"/>
                            <TextBlock Style="{StaticResource FieldHelpStyle}"
                                       Text="Primary key type (int, Guid…)."/>
                        </StackPanel>

                        <!-- Domain -->
                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,6,0,0">
                            <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                     materialDesign:HintAssist.Hint="Domain"
                                     Text="{Binding EntityDomain, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     IsEnabled="{Binding IsEntitySelected}"/>
                            <TextBlock Style="{StaticResource FieldHelpStyle}"
                                       Text="Business folder (derived from namespace)."/>
                        </StackPanel>

                        <!-- Ancestor Team -->
                        <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,6,0,0">
                            <TextBox Style="{StaticResource MaterialDesignFilledTextBox}"
                                     materialDesign:HintAssist.Hint="Ancestor Team"
                                     Text="{Binding AncestorTeam, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                            <TextBlock Style="{StaticResource FieldHelpStyle}"
                                       Text="Parent team type (optional)."/>
                        </StackPanel>

                        <!-- Team Role Type ID (V7+) -->
                        <StackPanel Grid.Column="2" Grid.Row="2" Margin="0,6,0,0"
                                    Visibility="{Binding IsVisibleTeamRoleId, Converter={StaticResource BoolToVisConverter}}">
                            <Grid>
                                <materialDesign:NumericUpDown Style="{StaticResource MaterialDesignFilledNumericUpDown}"
                                                              materialDesign:HintAssist.Hint="Team Role Type ID"
                                                              Value="{Binding TeamRoleId}"
                                                              IsEnabled="{Binding IsTeam}"/>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,6,8,0" Padding="4,1" CornerRadius="3"
                                        Background="{DynamicResource MaterialDesign.Brush.Primary}">
                                    <TextBlock Text="V7+" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </Grid>
                            <TextBlock Style="{StaticResource FieldHelpStyle}"
                                       Text="ID in the RoleType table (e.g. 2 = Squad Role). Required when Team is enabled."/>
                        </StackPanel>

                        <!-- Already generated warning -->
                        <Border Grid.Row="3" Grid.ColumnSpan="3" Margin="0,8,0,0"
                                Padding="10,8" CornerRadius="4"
                                Background="#33FF8C00"
                                BorderBrush="Orange" BorderThickness="1"
                                Visibility="{Binding WasAlreadyGenerated, Converter={StaticResource BoolToVisConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertOutline" Height="18" Width="18"
                                                         Foreground="Orange" VerticalAlignment="Center"/>
                                <TextBlock Text="A generation has already been performed for this entity"
                                           Foreground="Orange" FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Section 2: Features -->
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="② FEATURES"/>
                    <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                               Text="Interfaces implemented by the entity. Affects generated columns and mapping."/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <!-- Team -->
                        <Border Grid.Column="0" Grid.Row="0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTeam}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <CheckBox IsChecked="{Binding IsTeam, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEntitySelected}">
                                    <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Team"/>
                                </CheckBox>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="Entity managed by a team (access rights)."/>
                            </StackPanel>
                        </Border>

                        <!-- Versioned -->
                        <Border Grid.Column="2" Grid.Row="0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVersioned}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <CheckBox IsChecked="{Binding IsVersioned, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsVersionedEnabled}">
                                    <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Versioned"/>
                                </CheckBox>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="Full history of changes."/>
                            </StackPanel>
                        </Border>

                        <!-- Fixable -->
                        <Border Grid.Column="0" Grid.Row="2">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFixable}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <CheckBox IsChecked="{Binding IsFixable, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEntitySelected}">
                                    <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Fixable"/>
                                </CheckBox>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="Allows pinning a row at the top of the list."/>
                            </StackPanel>
                        </Border>

                        <!-- Archivable -->
                        <Border Grid.Column="2" Grid.Row="2">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsArchivable}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <CheckBox IsChecked="{Binding IsArchivable, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEntitySelected}">
                                    <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Archivable"/>
                                </CheckBox>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="Logical deletion (soft-delete)."/>
                            </StackPanel>
                        </Border>

                        <!-- Use dedicated audit (V6+) -->
                        <Border Grid.Column="0" Grid.Row="4"
                                Visibility="{Binding IsVisibleUseDedicatedAudit, Converter={StaticResource BoolToVisConverter}}">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource FeatureTileStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseDedicatedAudit}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <CheckBox IsChecked="{Binding UseDedicatedAudit, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsAuditable}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource FeatureTitleStyle}" Text="Dedicated audit"/>
                                        <Border Margin="8,0,0,0" Padding="4,1" CornerRadius="3"
                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="V6+" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </CheckBox>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="Uses a dedicated audit table for this entity."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================= Row 1: Mapping panel ================= -->
        <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header: title + contextual action buttons -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="③ PROPERTY MAPPING"/>
                            <TextBlock Style="{StaticResource SectionSubtitleStyle}"
                                       Text="Tick a property to add it to the DTO. The mapping editor appears inline below each selected property."/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Padding="10,4" MinWidth="0" Margin="0,0,8,0"
                                    IsEnabled="{Binding CanReorderMappingProperties}"
                                    Command="{x:Static materialDesign:DrawerHost.OpenDrawerCommand}"
                                    CommandParameter="{x:Static Dock.Right}"
                                    ToolTip="Open the reorder panel (requires at least 2 mapped properties)">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="SwapVertical" Height="16" Width="16" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Reorder" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Padding="10,4" MinWidth="0"
                                    Command="{Binding RemoveAllMappingPropertiesCommand}"
                                    IsEnabled="{Binding HasMappingProperties}"
                                    ToolTip="Uncheck every mapped property">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CloseCircleOutline" Height="16" Width="16" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Uncheck all" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Unified tree: checkbox + inline mapping editor per selected property -->
                    <Border Grid.Row="1" CornerRadius="4" BorderThickness="1"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}"
                            Margin="0,8,0,0">
                            <TreeView Name="ClassTreeView"
                                      ItemsSource="{Binding EntityProperties}"
                                      HorizontalContentAlignment="Stretch"
                                      BorderThickness="0">
                                <!-- Replace the TreeView's default internal ScrollViewer with a plain
                                     ItemsPresenter so mouse wheel events bubble up to the outer ScrollViewer. -->
                                <TreeView.Template>
                                    <ControlTemplate TargetType="{x:Type TreeView}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ItemsPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </TreeView.Template>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <Setter Property="Padding" Value="2"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <!-- Retemplate so the Header column spans * instead of Auto,
                                             allowing the inline mapping card to stretch to full width. -->
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type TreeViewItem}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition MinWidth="19" Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition/>
                                                        </Grid.RowDefinitions>
                                                        <ToggleButton x:Name="Expander"
                                                                      ClickMode="Press"
                                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      Style="{StaticResource MaterialDesignExpandCollapseToggleStyle}"
                                                                      Focusable="False"/>
                                                        <Border x:Name="Bd"
                                                                Grid.Column="1"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                Padding="{TemplateBinding Padding}"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter x:Name="PART_Header"
                                                                              ContentSource="Header"
                                                                              HorizontalAlignment="Stretch"
                                                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                        </Border>
                                                        <!-- Visible vertical tree-line on the left of children,
                                                             aligned under the expander of the parent. Opacity is applied
                                                             to the brush only so it doesn't fade the children content. -->
                                                        <Border x:Name="ChildrenHost"
                                                                Grid.Row="1" Grid.Column="1"
                                                                Margin="-8,0,0,0"
                                                                BorderThickness="2,0,0,0">
                                                            <Border.BorderBrush>
                                                                <SolidColorBrush Color="{Binding Color, Source={StaticResource MaterialDesign.Brush.Primary}}" Opacity="0.5"/>
                                                            </Border.BorderBrush>
                                                            <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0"/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsExpanded" Value="False">
                                                            <Setter TargetName="ChildrenHost" Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                        <Trigger Property="HasItems" Value="False">
                                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                            <Setter TargetName="ChildrenHost" Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type local:EntityProperty}" ItemsSource="{Binding Properties}">
                                    <StackPanel Orientation="Vertical" Margin="0,2">
                                        <!-- Header row: checkbox + name + type -->
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Type, StringFormat=({0})}"
                                                       Margin="6,0,0,0" VerticalAlignment="Center" Opacity="0.6"/>
                                        </StackPanel>

                                        <!-- Inline mapping editor: visible only when property is checked -->
                                        <Border Margin="26,6,8,6" Padding="12,10" CornerRadius="6"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                                                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel>
                                                <!-- Type info line -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="Source type:" FontSize="10" Style="{StaticResource Text.Caption}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding MappingEntityProperty.EntityType}" FontSize="10" FontWeight="SemiBold" Margin="4,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Mapping type:" FontSize="10" Style="{StaticResource Text.Caption}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding MappingEntityProperty.MappingType}" FontSize="10" FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Single-row layout: Mapping name (stretch) +
                                                     contextual combos + Required + Parent Id.
                                                     Collapsed columns shrink to 0 so simple properties stay compact. -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" MinWidth="180"/>
                                                        <ColumnDefinition Width="auto"/>
                                                        <ColumnDefinition Width="auto"/>
                                                        <ColumnDefinition Width="auto"/>
                                                        <ColumnDefinition Width="auto"/>
                                                        <ColumnDefinition Width="auto"/>
                                                        <ColumnDefinition Width="auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBox materialDesign:HintAssist.Hint="Mapping name"
                                                                 Text="{Binding MappingEntityProperty.MappingName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignFilledTextBox}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding MappingEntityProperty.HasMappingNameError}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="Red"/>
                                                                            <Setter Property="BorderThickness" Value="1"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>
                                                        <TextBlock Text="{Binding MappingEntityProperty.MappingNameError}"
                                                                   Foreground="Red" FontSize="10" Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding MappingEntityProperty.HasMappingNameError}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <ComboBox Grid.Column="1" MinWidth="130" Margin="12,0,0,0" VerticalAlignment="Center"
                                                              Style="{StaticResource MaterialDesignFilledComboBox}"
                                                              materialDesign:HintAssist.Hint="Date type"
                                                              ItemsSource="{Binding MappingEntityProperty.MappingDateTypes}"
                                                              SelectedValue="{Binding MappingEntityProperty.MappingDateType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                              Visibility="{Binding MappingEntityProperty.IsVisibleDateTypesComboxBox, Converter={StaticResource BoolToVisConverter}}"/>

                                                    <ComboBox Grid.Column="2" MinWidth="150" Margin="12,0,0,0" VerticalAlignment="Center"
                                                              Style="{StaticResource MaterialDesignFilledComboBox}"
                                                              materialDesign:HintAssist.Hint="Option entity Id"
                                                              ItemsSource="{Binding MappingEntityProperty.OptionEntityIdProperties}"
                                                              SelectedValue="{Binding MappingEntityProperty.OptionEntityIdProperty, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                              Visibility="{Binding MappingEntityProperty.IsOption, Converter={StaticResource BoolToVisConverter}}"/>

                                                    <ComboBox Grid.Column="3" MinWidth="120" Margin="12,0,0,0" VerticalAlignment="Center"
                                                              Style="{StaticResource MaterialDesignFilledComboBox}"
                                                              materialDesign:HintAssist.Hint="Option Id"
                                                              ItemsSource="{Binding MappingEntityProperty.OptionIdProperties}"
                                                              SelectedValue="{Binding MappingEntityProperty.OptionIdProperty, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                              Visibility="{Binding MappingEntityProperty.IsVisibleOptionPropertiesComboBox, Converter={StaticResource BoolToVisConverter}}"/>

                                                    <ComboBox Grid.Column="4" MinWidth="130" Margin="12,0,0,0" VerticalAlignment="Center"
                                                              Style="{StaticResource MaterialDesignFilledComboBox}"
                                                              materialDesign:HintAssist.Hint="Option display"
                                                              ItemsSource="{Binding MappingEntityProperty.OptionDisplayProperties}"
                                                              SelectedValue="{Binding MappingEntityProperty.OptionDisplayProperty, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                              Visibility="{Binding MappingEntityProperty.IsVisibleOptionPropertiesComboBox, Converter={StaticResource BoolToVisConverter}}"/>

                                                    <CheckBox Grid.Column="5" Margin="16,0,0,0"
                                                              Content="Required"
                                                              IsChecked="{Binding MappingEntityProperty.IsRequired, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                              VerticalAlignment="Center"/>

                                                    <CheckBox Grid.Column="6" Margin="12,0,0,0"
                                                              Content="Parent Id"
                                                              IsChecked="{Binding MappingEntityProperty.IsParent, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                              Command="{Binding DataContext.SetMappedPropertyIsParentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding MappingEntityProperty}"
                                                              VerticalAlignment="Center"
                                                              Visibility="{Binding MappingEntityProperty.IsVisibleIsParentCheckbox, Converter={StaticResource BoolToVisConverter}}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                            </TreeView>
                    </Border>
                </Grid>
            </Border>

    </Grid>
    </ScrollViewer>

        <!-- ================= Fixed footer ================= -->
        <Border Grid.Row="1"
                Background="Transparent"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        x:Name="GenerateButton"
                        Style="{StaticResource Button.SecondaryAction}"
                        Height="40" Padding="16,0" MinWidth="150"
                        Command="{Binding GenerateCommand}"
                        IsEnabled="{Binding IsGenerationEnabled}"
                        ToolTip="{Binding GenerateButtonTooltip}"
                        ToolTipService.ShowOnDisabled="True"
                        ToolTipService.InitialShowDelay="200">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="FlashOutline" Height="20" Width="20" VerticalAlignment="Center"/>
                        <TextBlock Text="Generate" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
    </materialDesign:DrawerHost>
</UserControl>
